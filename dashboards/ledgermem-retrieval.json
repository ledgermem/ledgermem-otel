{
  "title": "LedgerMem — retrieval quality",
  "uid": "ledgermem-retrieval",
  "tags": ["ledgermem"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Recall@5 (rolling 1h, by strategy)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "avg by (strategy) (avg_over_time(ledgermem_retrieval_recall_at_5[1h]))",
          "legendFormat": "{{strategy}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Search latency p95 (s, by strategy)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, strategy) (rate(ledgermem_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "{{strategy}}"
        }
      ]
    },
    {
      "type": "table",
      "title": "Top 10 slowest queries (last 1h)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "topk(10, max_over_time(ledgermem_retrieval_query_duration_seconds[1h]))",
          "format": "table"
        }
      ]
    }
  ]
}
