{
  "title": "Mnemo — API health",
  "uid": "getmnemo-api-health",
  "tags": ["getmnemo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(getmnemo_http_requests_total, deployment_environment)",
        "current": { "text": "prod", "value": "prod" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests per second (by status family)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status_family) (rate(getmnemo_http_requests_total{deployment_environment=\"$env\"}[1m]))",
          "legendFormat": "{{status_family}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99 (s)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(getmnemo_http_request_duration_seconds_bucket{deployment_environment=\"$env\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(getmnemo_http_request_duration_seconds_bucket{deployment_environment=\"$env\"}[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(getmnemo_http_request_duration_seconds_bucket{deployment_environment=\"$env\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "stat",
      "title": "5xx rate (last 5m)",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(getmnemo_http_requests_total{status=~\"5..\",deployment_environment=\"$env\"}[5m])) / sum(rate(getmnemo_http_requests_total{deployment_environment=\"$env\"}[5m]))",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.005 }, { "color": "red", "value": 0.01 }] } } }
    }
  ]
}
